<?xml version="1.0" encoding="utf-8"?>
<!-- Riga piano: evidenziata con riquadro arrotondato quando selezionata o premuta -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#E8EAF6" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#3F51B5" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#F0F1F7" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5F6FA" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#E0E2EA" />
        </shape>
    </item>
</selector>
